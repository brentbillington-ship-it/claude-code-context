# claude-code-context/.gitignore
# Personal/local overrides
.claude/settings.local.json

# Binary archives — playbook snapshots are unzipped in-tree; the .zip is redundant
*.zip

# Machine-local secret denylist for the pre-commit scan — never commit
.githooks/secret-denylist.local

# Personal memory file with local URLs/credentials — never commit
CLAUDE.local.md

# Assembled plugin payload — built by tools/build-plugin.sh from canonical sources
plugin/skills/
plugin/agents/
plugin/hooks/scripts/

# Automation-generated reports and backups (playbook/automation/README.md)
playbook/automation/retro_report.md
playbook/automation/retro_log.md
playbook/automation/tune_log.md
playbook/automation/_tuner_backup/

# Assembled Halff export — built by tools/build-halff-export.sh
halff-export/
